# Copy to .env and fill in. .env is gitignored.

# Required
ANTHROPIC_API_KEY=

# Recommended (collectors degrade gracefully without these but signal is reduced)
GITHUB_TOKEN=
PRODUCT_HUNT_TOKEN=
FIRECRAWL_API_KEY=

# Optional — Google Sheets export (skip with `sourcer export --no-sheets`)
GOOGLE_SA_PATH=
GOOGLE_SHEET_ID=
